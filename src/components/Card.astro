---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  icon?: string;
}
const { title, icon } = Astro.props;
---

<div
  class="flex h-full flex-col gap-3 rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md dark:border-zinc-700 dark:bg-zinc-800/60"
>
  {
    icon && (
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-600 dark:bg-blue-500/15 dark:text-blue-300">
        <Icon name={icon} class="h-6 w-6" />
      </div>
    )
  }
  <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">
    {title}
  </h3>
  <p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-300">
    <slot />
  </p>
</div>
