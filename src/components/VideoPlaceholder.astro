---
import { Icon } from "astro-icon/components";

interface Props {
  label?: string;
}
const { label = "Real-robot video coming soon" } = Astro.props;
---

<div
  class="not-prose flex aspect-video w-full flex-col items-center justify-center gap-3 rounded-2xl border border-dashed border-zinc-300 bg-zinc-50 text-zinc-400 dark:border-zinc-600 dark:bg-zinc-800/40 dark:text-zinc-500"
>
  <Icon name="ri:play-circle-line" class="h-12 w-12" />
  <span class="text-sm font-medium">{label}</span>
</div>
