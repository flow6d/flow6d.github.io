---
interface Props {
  fullWidth?: boolean;
}

const { fullWidth = false } = Astro.props;
---

<figure
  class:list={[
    "not-prose mx-auto my-10 w-full overflow-hidden rounded-2xl border border-zinc-200/90 bg-gradient-to-br from-zinc-50 via-white to-blue-50/60 p-3 shadow-[0_12px_40px_-24px_rgba(15,23,42,0.35)] sm:p-5 dark:border-zinc-700/80 dark:from-zinc-900 dark:via-zinc-900 dark:to-blue-950/30",
    fullWidth ? "max-w-none" : "max-w-[54.4rem]",
  ]}
>
  <div
    class="flex w-full justify-center overflow-hidden rounded-xl border border-zinc-200/80 bg-white **:my-0 dark:border-zinc-700 dark:bg-zinc-950"
  >
    <slot name="figure" />
  </div>
  <figcaption
    class="mx-auto max-w-3xl px-3 pt-4 pb-1 text-center text-sm leading-relaxed text-zinc-600 sm:text-base dark:text-zinc-300"
  >
    <slot name="caption" />
  </figcaption>
</figure>
